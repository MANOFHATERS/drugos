# DrugOS Graph Module — Environment Variables
# Copy this file to .env and fill in the values.

# Neo4j Database (required)
DRUGOS_NEO4J_PASSWORD=

# Optional: Override default Neo4j connection settings
# DRUGOS_NEO4J_URI=bolt://localhost:7687
# DRUGOS_NEO4J_USER=neo4j
# DRUGOS_NEO4J_DATABASE=neo4j

# Optional: MLflow tracking
# MLFLOW_TRACKING_URI=http://localhost:5000

# Optional: HuggingFace cache directory (for ChemBERTa)
# HF_HOME=~/.cache/huggingface
